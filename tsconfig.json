{
  "extends": "./tsconfig.base.json",
  "include": ["*.ts", "config/**/*.ts"],
  "exclude": ["**/dist/**", "**/node_modules/**"],
  "compilerOptions": {
    "target": "ES2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,
    "noEmit": true
  }
}
