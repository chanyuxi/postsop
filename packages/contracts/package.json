{
  "name": "@postsop/contracts",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "description": "Shared type definitions and API contracts between client and server",
  "author": "chanyuxi",
  "license": "ISC",
  "exports": {
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js",
      "require": "./dist/*/index.js",
      "default": "./dist/*/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "http-status-codes": "^2.3.0",
    "zod": "^4.3.6"
  }
}
