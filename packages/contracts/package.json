{
  "name": "@postsop/contracts",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "description": "Shared type definitions and API contracts between client and server",
  "author": "chanyuxi",
  "license": "ISC",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js",
      "require": "./dist/http/index.js",
      "default": "./dist/http/index.js"
    },
    "./permissions": {
      "types": "./dist/core/permissions.d.ts",
      "import": "./dist/core/permissions.js",
      "require": "./dist/core/permissions.js",
      "default": "./dist/core/permissions.js"
    },
    "./*": {
      "types": "./dist/modules/*/index.d.ts",
      "import": "./dist/modules/*/index.js",
      "require": "./dist/modules/*/index.js",
      "default": "./dist/modules/*/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@postsop/access-control": "workspace:*",
    "http-status-codes": "^2.3.0",
    "zod": "^4.3.6"
  }
}
