{
  "name": "@postsop/apis",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "description": "Shared API interfaces and client utilities for postsop",
  "author": "chanyuxi",
  "license": "ISC",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/package-build.mjs",
    "dev": "node ../../scripts/package-build.mjs --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@postsop/contracts": "workspace:*",
    "@postsop/types": "workspace:*",
    "axios": "^1.13.6",
    "http-status-codes": "^2.3.0"
  }
}
