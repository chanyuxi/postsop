{
  "name": "@postsop/backend",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "author": "",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nest dev",
    "build": "nest build",
    "build:webpack-demo": "nest build --builder webpack --webpackPath webpack.demo.config.cjs",
    "build:watch": "nest build --watch",
    "start": "nest start",
    "start:dev": "pnpm run dev",
    "start:dev:nest": "cross-env NODE_ENV=development nest start --watch",
    "start:dev:webpack-demo": "cross-env NODE_ENV=development nest start --builder webpack --watch --webpackPath webpack.demo.config.cjs",
    "start:debug": "nest start --debug --watch",
    "start:webpack-demo": "cross-env NODE_ENV=development nest start --builder webpack --webpackPath webpack.demo.config.cjs",
    "start:prod": "node dist/main",
    "lint": "pnpm --dir ../.. exec eslint apps/server --cache",
    "lint:fix": "pnpm --dir ../.. exec eslint apps/server --fix --cache",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@postsop/contracts": "workspace:*",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/lodash": "^4.17.24",
    "cache-manager": "^7.2.8",
    "lodash": "^4.17.23",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.18",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
