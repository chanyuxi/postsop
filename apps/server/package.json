{
  "name": "@postsop/server",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS backend server for postsop",
  "author": "chanyuxi",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:watch": "nest build --watch",
    "dev": "cross-env NODE_ENV=development nest start --watch",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:permissions:check": "tsx prisma/permissions.ts check",
    "db:permissions:sync": "tsx prisma/permissions.ts sync",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "lint": "pnpm --dir ../.. exec eslint apps/server --cache",
    "lint:fix": "pnpm --dir ../.. exec eslint apps/server --fix --cache",
    "start": "node dist/main",
    "start:debug": "nest start --debug --watch",
    "test": "jest --config ./jest.unit.config.json",
    "test:cov": "jest --config ./jest.unit.config.json --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config ./jest.unit.config.json --runInBand",
    "test:e2e": "jest --config ./jest.e2e.config.json",
    "test:watch": "jest --config ./jest.unit.config.json --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@postsop/access-control": "workspace:*",
    "@postsop/contracts": "workspace:*",
    "@postsop/types": "workspace:*",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/lodash": "^4.17.24",
    "cache-manager": "^7.2.8",
    "lodash": "^4.17.23",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.18",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
