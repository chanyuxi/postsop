{
  "name": "postsop-workspace",
  "version": "0.1.91",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "prepare": "husky",
    "lint": "turbo run lint lint:root",
    "lint:root": "eslint . --cache --ignore-pattern .turbo/** --ignore-pattern apps/** --ignore-pattern packages/**",
    "lint:fix": "eslint . --fix --cache",
    "lint-staged": "lint-staged",
    "type-check": "turbo run type-check type-check:root",
    "type-check:root": "tsc -p tsconfig.json --noEmit",
    "test": "turbo run test",
    "build": "turbo run build",
    "contracts:dev": "turbo run dev --filter=@postsop/shared-contracts",
    "contracts:watch": "pnpm run contracts:dev",
    "mobile:android": "pnpm --filter @postsop/mobile android",
    "mobile:ios": "pnpm --filter @postsop/mobile ios",
    "mobile:lint": "pnpm --filter @postsop/mobile lint",
    "mobile:lint:fix": "pnpm --filter @postsop/mobile lint:fix",
    "mobile:type-check": "pnpm --filter @postsop/mobile type-check",
    "mobile:start": "pnpm --filter @postsop/mobile start",
    "mobile:test": "pnpm --filter @postsop/mobile test",
    "mobile:generate:tailwindcss:output": "pnpm --filter @postsop/mobile generate:tailwindcss:output",
    "server:build": "pnpm --filter @postsop/backend build",
    "server:build:webpack-demo": "pnpm --filter @postsop/backend build:webpack-demo",
    "server:dev": "turbo run dev --filter=@postsop/backend",
    "server:lint": "pnpm --filter @postsop/backend lint",
    "server:lint:fix": "pnpm --filter @postsop/backend lint:fix",
    "server:type-check": "pnpm --filter @postsop/backend type-check",
    "server:start": "pnpm --filter @postsop/backend start",
    "server:start:dev": "pnpm run server:dev",
    "server:start:dev:webpack-demo": "pnpm --filter @postsop/backend start:dev:webpack-demo",
    "server:start:debug": "pnpm --filter @postsop/backend start:debug",
    "server:start:webpack-demo": "pnpm --filter @postsop/backend start:webpack-demo",
    "server:start:prod": "pnpm --filter @postsop/backend start:prod",
    "server:test": "pnpm --filter @postsop/backend test",
    "server:test:watch": "pnpm --filter @postsop/backend test:watch",
    "server:test:cov": "pnpm --filter @postsop/backend test:cov",
    "server:test:debug": "pnpm --filter @postsop/backend test:debug",
    "server:test:e2e": "pnpm --filter @postsop/backend test:e2e",
    "server:prisma:generate": "pnpm --filter @postsop/backend prisma:generate",
    "server:prisma:migrate": "pnpm --filter @postsop/backend prisma:migrate",
    "server:prisma:seed": "pnpm --filter @postsop/backend prisma:seed",
    "server:prisma:studio": "pnpm --filter @postsop/backend prisma:studio"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^9.39.4",
    "@react-native/eslint-plugin": "^0.84.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": "eslint --fix --cache --no-warn-ignored",
    "*.{json,jsonc}": "eslint --fix --cache --no-warn-ignored"
  }
}
