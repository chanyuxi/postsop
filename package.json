{
  "name": "postsop-workspace",
  "version": "0.1.91",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "build": "turbo run build",
    "contracts:watch": "turbo run dev --filter=@postsop/contracts",
    "dev": "turbo run dev",
    "lint": "turbo run lint lint:root",
    "lint:fix": "eslint . --fix --cache",
    "lint:root": "eslint . --cache --ignore-pattern .turbo/** --ignore-pattern apps/** --ignore-pattern packages/**",
    "lint-staged": "lint-staged",
    "mobile:android": "pnpm --filter @postsop/mobile android",
    "mobile:ios": "pnpm --filter @postsop/mobile ios",
    "mobile:start": "pnpm --filter @postsop/mobile start",
    "server:build": "pnpm --filter @postsop/backend build",
    "server:db:generate": "pnpm --filter @postsop/backend db:generate",
    "server:db:migrate": "pnpm --filter @postsop/backend db:migrate",
    "server:db:seed": "pnpm --filter @postsop/backend db:seed",
    "server:db:studio": "pnpm --filter @postsop/backend db:studio",
    "server:dev": "turbo run dev --filter=@postsop/backend",
    "server:lint": "pnpm --filter @postsop/backend lint",
    "server:test": "pnpm --filter @postsop/backend test",
    "server:type-check": "pnpm --filter @postsop/backend type-check",
    "prepare": "husky",
    "test": "turbo run test",
    "type-check": "turbo run type-check type-check:root",
    "type-check:root": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^9.39.4",
    "@react-native/eslint-plugin": "^0.84.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": "eslint --fix --cache --no-warn-ignored",
    "*.{json,jsonc}": "eslint --fix --cache --no-warn-ignored"
  }
}
