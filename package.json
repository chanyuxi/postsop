{
  "name": "postsop-workspace",
  "version": "0.1.91",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "android": "pnpm --dir apps/mobile android",
    "ios": "pnpm --dir apps/mobile ios",
    "lint": "pnpm --dir apps/mobile lint",
    "lint:fix": "pnpm --dir apps/mobile lint:fix",
    "type-check": "pnpm --dir apps/mobile type-check",
    "start": "pnpm --dir apps/mobile start",
    "test": "pnpm --dir apps/mobile test",
    "prepare": "husky",
    "generate:tailwindcss:output": "pnpm --dir apps/mobile generate:tailwindcss:output"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">=22.11.0"
  }
}
