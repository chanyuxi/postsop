{
  "name": "postsop-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "description": "Monorepo workspace for the postsop full-stack application",
  "author": "chanyuxi",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "build": "turbo run build",
    "contracts:watch": "turbo run dev --filter=@postsop/contracts",
    "dev": "turbo run dev",
    "lint": "turbo run lint lint:root",
    "lint:fix": "eslint . --fix --cache",
    "lint:root": "eslint . --cache --ignore-pattern .turbo/** --ignore-pattern apps/** --ignore-pattern packages/**",
    "lint-staged": "lint-staged",
    "client-app:android": "pnpm --filter @postsop/client-app android",
    "client-app:ios": "pnpm --filter @postsop/client-app ios",
    "client-app:start": "pnpm --filter @postsop/client-app start",
    "server:build": "pnpm --filter @postsop/server build",
    "server:db:generate": "pnpm --filter @postsop/server db:generate",
    "server:db:migrate": "pnpm --filter @postsop/server db:migrate",
    "server:db:seed": "pnpm --filter @postsop/server db:seed",
    "server:db:studio": "pnpm --filter @postsop/server db:studio",
    "server:dev": "turbo run dev --filter=@postsop/server",
    "server:lint": "pnpm --filter @postsop/server lint",
    "server:test": "pnpm --filter @postsop/server test",
    "server:type-check": "pnpm --filter @postsop/server type-check",
    "prepare": "husky",
    "test": "turbo run test",
    "type-check": "turbo run type-check type-check:root",
    "type-check:root": "tsc --noEmit"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^9.39.4",
    "@postsop/configs": "workspace:*",
    "@react-native/eslint-plugin": "^0.84.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
