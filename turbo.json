{
  "$schema": "./node_modules/turbo/schema.json",
  "ui": "tui",
  "noUpdateNotifier": true,
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../module-shim.d.ts",
        "../../scripts/**",
        "../../tsconfig.json",
        "../../configs/typescript/tsconfig*.json",
        "!dist/**",
        "!.turbo/**",
        "!coverage/**"
      ],
      "outputs": ["dist/**"]
    },
    "build:watch": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../module-shim.d.ts",
        "../../scripts/**",
        "../../tsconfig.json",
        "../../configs/typescript/tsconfig*.json",
        "!dist/**",
        "!.turbo/**",
        "!coverage/**"
      ],
      "cache": false,
      "persistent": true
    },
    "dev": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../module-shim.d.ts",
        "../../scripts/**",
        "../../tsconfig.json",
        "../../configs/typescript/tsconfig*.json",
        "!dist/**",
        "!.turbo/**",
        "!coverage/**"
      ],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "!dist/**", "!.turbo/**", "!coverage/**"],
      "outputs": []
    },
    "type-check": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../module-shim.d.ts",
        "../../tsconfig.json",
        "../../configs/typescript/tsconfig*.json",
        "!dist/**",
        "!.turbo/**",
        "!coverage/**"
      ],
      "outputs": []
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "!dist/**", "!.turbo/**", "!coverage/**"],
      "outputs": ["coverage/**"]
    },
    "//#lint:root": {
      "outputs": []
    },
    "//#type-check:root": {
      "outputs": []
    }
  }
}
