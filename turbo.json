{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!dist/**", "!.turbo/**", "!coverage/**"],
      "outputs": ["dist/**"]
    },
    "build:watch": {
      "inputs": ["$TURBO_DEFAULT$", "!dist/**", "!.turbo/**", "!coverage/**"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "!dist/**", "!.turbo/**", "!coverage/**"],
      "outputs": []
    },
    "type-check": {
      "inputs": ["$TURBO_DEFAULT$", "!dist/**", "!.turbo/**", "!coverage/**"],
      "outputs": []
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "!dist/**", "!.turbo/**", "!coverage/**"],
      "outputs": ["coverage/**"]
    },
    "//#lint:root": {
      "outputs": []
    },
    "//#type-check:root": {
      "outputs": []
    }
  }
}
