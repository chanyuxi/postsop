{
  "$schema": "./node_modules/turbo/schema.json",
  "ui": "tui",
  "noUpdateNotifier": true,
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../module-shim.d.ts",
        "../../tsconfig.json",
        "../../tsconfig.base.json",
        "../../tsconfig.build.json",
        "!dist/**",
        "!.turbo/**",
        "!coverage/**"
      ],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../module-shim.d.ts",
        "../../tsconfig.json",
        "../../tsconfig.base.json",
        "../../tsconfig.build.json",
        "!dist/**",
        "!.turbo/**",
        "!coverage/**"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:cov": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    }
  }
}
